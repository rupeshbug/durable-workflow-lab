{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "worker": "tsx watch src/worker.ts"
  },
  "dependencies": {
    "@durable-workflow-lab/env": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "bullmq": "^5.80.9",
    "dotenv": "catalog:",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@durable-workflow-lab/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "catalog:"
  }
}
